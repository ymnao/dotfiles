{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(make help:*)",
      "Bash(make install:*)",
      "Bash(make link:*)",
      "Bash(make update:*)",
      "Bash(make brewfile:*)",
      "Bash(make clean:*)",
      "Bash(bash scripts/install.sh:*)",
      "Bash(bash scripts/link.sh:*)",
      "Bash(brew install:*)",
      "Bash(brew update:*)",
      "Bash(brew upgrade:*)",
      "Bash(brew cleanup:*)",
      "Bash(brew bundle:*)",
      "Bash(brew list:*)",
      "Bash(brew info:*)",
      "Bash(brew tap:*)",
      "Bash(brew --version)"
    ],
    "deny": [
      "Bash(brew uninstall:*)",
      "Bash(brew remove:*)",
      "Bash(brew untap:*)"
    ]
  },
  "sandbox": {
    "filesystem": {
      "allowWrite": [
        "~/.config",
        "~/.claude",
        "~/.npmrc",
        "/opt/homebrew",
        "/usr/local",
        "~/Library/Caches/Homebrew",
        "~/Library/Logs/Homebrew"
      ]
    },
    "network": {
      "allowedDomains": [
        "formulae.brew.sh",
        "ghcr.io",
        "raw.githubusercontent.com",
        "github.com",
        "api.github.com",
        "codeload.github.com",
        "objects.githubusercontent.com"
      ]
    }
  }
}
