{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(bun install:*)",
      "Bash(bun test:*)",
      "Bash(bun run *)",
      "Bash(bun exec *)",
      "Bash(bun typecheck:*)",
      "Bash(bun build:*)",
      "Bash(bun lint:*)",
      "Bash(bun format:*)",
      "Bash(bun dev:*)",
      "Bash(bun start:*)",
      "Bash(node *)",
      "Bash(tsx *)",
      "Bash(tsc:*)"
    ],
    "ask": [
      "Bash(bun add *)",
      "Bash(bun remove *)",
      "Bash(bun update *)",
      "Bash(bun pm trust *)",
      "Bash(bunx *)",
      "Bash(bun x *)",
      "Bash(npx *)"
    ],
    "deny": [
      "Bash(bun install -g *)",
      "Bash(bun add -g *)",
      "Bash(npm install -g *)",
      "Bash(bun publish:*)",
      "Bash(npm publish:*)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Edit(node_modules/**)",
      "Edit(bun.lockb)",
      "Edit(bun.lock)",
      "Edit(pnpm-lock.yaml)",
      "Edit(package-lock.json)",
      "Edit(yarn.lock)",
      "Read(.env)",
      "Read(.env.*)"
    ]
  },
  "sandbox": {
    "filesystem": {
      "allowWrite": [
        "~/.bun"
      ]
    }
  }
}
