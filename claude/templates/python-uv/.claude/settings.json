{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(uv sync:*)",
      "Bash(uv lock:*)",
      "Bash(uv add:*)",
      "Bash(uv remove:*)",
      "Bash(uv tree:*)",
      "Bash(uv run *)",
      "Bash(uv pip install:*)",
      "Bash(pip install:*)",
      "Bash(pip3 install:*)",
      "Bash(python -m pip install:*)",
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(pytest:*)",
      "Bash(ruff:*)"
    ],
    "ask": [
      "Bash(uvx *)",
      "Bash(uv tool install *)",
      "Bash(pip install --user *)"
    ],
    "deny": [
      "Bash(uv publish:*)",
      "Bash(uv pip install --system *)",
      "Bash(pip install --system *)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Edit(uv.lock)",
      "Edit(.venv/**)",
      "Edit(__pycache__/**)",
      "Read(.env)",
      "Read(.env.*)"
    ]
  },
  "sandbox": {
    "filesystem": {
      "allowWrite": [
        "~/.cache/uv",
        "~/Library/Caches/uv",
        "~/.cache/pip",
        "~/Library/Caches/pip"
      ]
    }
  }
}
