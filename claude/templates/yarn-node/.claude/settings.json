{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(yarn install:*)",
      "Bash(yarn test:*)",
      "Bash(yarn run *)",
      "Bash(yarn exec *)",
      "Bash(yarn typecheck:*)",
      "Bash(yarn build:*)",
      "Bash(yarn lint:*)",
      "Bash(yarn format:*)",
      "Bash(yarn dev:*)",
      "Bash(yarn start:*)",
      "Bash(node *)",
      "Bash(tsx *)",
      "Bash(tsc:*)"
    ],
    "ask": [
      "Bash(yarn add *)",
      "Bash(yarn remove *)",
      "Bash(yarn update *)",
      "Bash(yarn upgrade *)",
      "Bash(yarn dlx *)",
      "Bash(npx *)"
    ],
    "deny": [
      "Bash(yarn global add *)",
      "Bash(npm install -g *)",
      "Bash(yarn publish:*)",
      "Bash(yarn npm publish:*)",
      "Bash(npm publish:*)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Edit(node_modules/**)",
      "Edit(yarn.lock)",
      "Edit(pnpm-lock.yaml)",
      "Edit(package-lock.json)",
      "Edit(.pnp.cjs)",
      "Edit(.pnp.loader.mjs)",
      "Edit(.yarn/cache/**)",
      "Read(.env)",
      "Read(.env.*)"
    ]
  },
  "sandbox": {
    "filesystem": {
      "allowWrite": [
        "~/.yarn",
        "~/Library/Caches/Yarn",
        "~/.cache/yarn",
        "~/.npm"
      ]
    }
  }
}
