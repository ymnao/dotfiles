{"name":"printf-sq-danger","expect":"allow","command":"printf %s '$(git reset --hard)'","reason":"シングルクォート内は展開されない"}
{"name":"echo-sq-rm","expect":"block","command":"echo 'rm -rf /'","reason":"現状挙動 (実測): $ を含まない sq はクォート除去で中身が残り rm -rf / として検出される。過剰だが安全側"}
{"name":"rm-rf-quoted-tilde","expect":"allow","command":"rm -rf '~'","reason":"クォート済み ~ はリテラル名"}
# --- allow: 非該当の類似コマンド ---
{"name":"git-push-plain","expect":"allow","command":"git push","reason":"通常 push"}
{"name":"git-push-origin","expect":"allow","command":"git push origin main","reason":"通常 push"}
{"name":"git-reset-soft","expect":"allow","command":"git reset --soft HEAD~1","reason":"soft は許可"}
{"name":"git-commit","expect":"allow","command":"git commit -m \"feat: x\"","reason":"通常コミット"}
{"name":"git-commit-amend","expect":"allow","command":"git commit --amend","reason":"hook 対象外 (AGENTS.md ルールのみ)"}
{"name":"git-rebase-local","expect":"allow","command":"git rebase -i HEAD~2","reason":"hook 対象外 (AGENTS.md ルールのみ)"}
{"name":"rm-single-file","expect":"allow","command":"rm file.txt","reason":"-rf なし"}
{"name":"rm-f-single","expect":"allow","command":"rm -f single.txt","reason":"-r なし"}
{"name":"chmod-755","expect":"allow","command":"chmod 755 x","reason":"777 以外"}
