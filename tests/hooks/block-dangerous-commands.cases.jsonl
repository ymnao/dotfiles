{"name":"eval-static","expect":"allow","command":"eval ls -la","reason":"静的リテラルの eval"}
{"name":"bash-c-static","expect":"allow","command":"bash -c \"echo hello\"","reason":"静的リテラルの -c"}
{"name":"bash-script-c","expect":"allow","command":"bash script.sh -c 'x'","reason":"-c は script の引数"}
{"name":"bash-dashdash-c","expect":"allow","command":"bash -- -c 'echo hi'","reason":"-- 以降は script 引数"}
