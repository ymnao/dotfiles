{"name":"eval-dynamic","expect":"block","command":"eval g$(printf it) reset --hard","reason":"eval 引数の動的展開"}
{"name":"bash-c-dynamic","expect":"block","command":"bash -c \"$(printf git) reset --hard\"","reason":"sh -c 引数の動的展開"}
{"name":"bash-c-sq-dynamic","expect":"block","command":"bash -c '$(date)'","reason":"sh -c シングルクォート内動的 (判定B)"}
{"name":"pipe-to-bash-dynamic","expect":"block","command":"printf %s \"$(printf git) reset --hard\" | bash","reason":"pipe 再パース経路"}
