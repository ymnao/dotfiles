{"name":"ls-pwd-sub","expect":"allow","command":"ls $(pwd)/subdir","reason":"引数位置"}
{"name":"wc-param-default","expect":"allow","command":"wc -l ${LOGFILE:-default.log}","reason":"引数位置のパラメータ展開"}
