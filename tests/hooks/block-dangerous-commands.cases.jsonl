# --- allow: 日常コマンド ---
{"name":"ls-la","expect":"allow","command":"ls -la","reason":"無害"}
{"name":"grep-src","expect":"allow","command":"grep -rn foo src/","reason":"無害"}
{"name":"npm-run-build","expect":"allow","command":"npm run build","reason":"無害"}
{"name":"make-test","expect":"allow","command":"make test","reason":"無害"}
{"name":"sed-print","expect":"allow","command":"sed -n 1,10p file.txt","reason":"無害"}
{"name":"runner-self","expect":"allow","command":"bash tests/run-hook-tests.sh","reason":"ランナー自身が誤検知されない"}
