{"name":"rm-r-f-separate","expect":"block","command":"rm -r -f /","reason":"フラグ分離形"}
{"name":"rm-long-flags","expect":"block","command":"rm --recursive --force /","reason":"long option 形"}
{"name":"rm-flags-reversed","expect":"block","command":"rm -f -R /","reason":"f→R 順"}
{"name":"rm-quoted-name","expect":"block","command":"'rm' -rf ~","reason":"コマンド名クォート分割"}
{"name":"rm-backslash","expect":"block","command":"r\\m -rf /","reason":"バックスラッシュ挿入"}
