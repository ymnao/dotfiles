# PR2 版との差分: cargo / go / gem / bundle の拡張ケースを追加
# --- PR6: cargo / go / gem / bundle (block) ---
{"name":"cargo-add","expect":"block","command":"cargo add serde","reason":"依存追加"}
{"name":"cargo-install","expect":"block","command":"cargo install ripgrep","reason":"バイナリ取得"}
{"name":"go-get","expect":"block","command":"go get github.com/x/y","reason":"依存追加 (go.mod 書き換え)"}
{"name":"go-install","expect":"block","command":"go install github.com/x/y@latest","reason":"バイナリ取得"}
{"name":"go-mod-tidy","expect":"block","command":"go mod tidy","reason":"依存追加を伴い得る"}
{"name":"gem-install","expect":"block","command":"gem install rails","reason":"依存追加"}
{"name":"bundle-add","expect":"block","command":"bundle add rspec","reason":"依存追加"}
{"name":"xargs-cargo","expect":"block","command":"echo ripgrep | xargs cargo install","reason":"引数注入ラッパー経由"}
